<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<GUI name="adsInGameMenuFleetFrame">
    <GuiElement profile="fs25_shopContainer">
        <GuiElement profile="fs25_shopHeaderPanel">
            <Bitmap profile="fs25_menuHeaderIconBg">
                <Bitmap profile="fs25_menuHeaderIcon" imageSliceId="gui.icon_ingameMenu_vehicles"/>
            </Bitmap>
            <Text profile="fs25_menuHeaderTitle" id="menuHeaderTitle" text="$l10n_ads_ingame_menu_title"/>
            <RoundCorner profile="fs25_shopMoneyBoxBg" id="moneyBoxBg"/>
            <BoxLayout profile="fs25_shopMoneyBox" id="moneyBox">
                <Text profile="fs25_shopBalance" id="balanceTitleElement" text="$l10n_ui_balance"/>
                <Text profile="fs25_shopMoney" id="balanceElement"/>
            </BoxLayout>
        </GuiElement>

        <GuiElement profile="ads_menuTableContainer">
            <GuiElement profile="fs25_statisticsHeaderBox">
                <Button profile="ads_menuHeaderButtonLeft" position="42px 0px" size="280px 40px" text="$l10n_ads_ingame_menu_header_vehicle" onClick="onClickVehicleHeader">
                    <Bitmap profile="fs25_vehiclesHeaderIconSortAscending" position="-10px 0px" id="iconVehicleAscending"/>
                    <Bitmap profile="fs25_vehiclesHeaderIconSortDescending" position="-10px 0px" id="iconVehicleDescending"/>
                </Button>
                <Button profile="ads_menuHeaderButtonRight" position="328px 0px" size="110px 40px" text="$l10n_ads_ingame_menu_header_age" onClick="onClickAgeHeader">
                    <Bitmap profile="fs25_vehiclesHeaderIconSortAscending" position="10px 0px" id="iconAgeAscending"/>
                    <Bitmap profile="fs25_vehiclesHeaderIconSortDescending" position="10px 0px" id="iconAgeDescending"/>
                </Button>
                <Button profile="ads_menuHeaderButtonRight" position="444px 0px" size="110px 40px" text="$l10n_ads_ingame_menu_header_working_hours" onClick="onClickWorkingHoursHeader">
                    <Bitmap profile="fs25_vehiclesHeaderIconSortAscending" position="10px 0px" id="iconHoursAscending"/>
                    <Bitmap profile="fs25_vehiclesHeaderIconSortDescending" position="10px 0px" id="iconHoursDescending"/>
                </Button>
                <Button profile="ads_menuHeaderButtonRight" position="560px 0px" size="130px 40px" text="$l10n_ads_ingame_menu_header_condition" onClick="onClickConditionHeader">
                    <Bitmap profile="fs25_vehiclesHeaderIconSortAscending" position="10px 0px" id="iconConditionAscending"/>
                    <Bitmap profile="fs25_vehiclesHeaderIconSortDescending" position="10px 0px" id="iconConditionDescending"/>
                </Button>
                <Button profile="ads_menuHeaderButtonRight" position="696px 0px" size="130px 40px" text="$l10n_ads_ingame_menu_header_interval" onClick="onClickIntervalHeader">
                    <Bitmap profile="fs25_vehiclesHeaderIconSortAscending" position="10px 0px" id="iconIntervalAscending"/>
                    <Bitmap profile="fs25_vehiclesHeaderIconSortDescending" position="10px 0px" id="iconIntervalDescending"/>
                </Button>
                <Button profile="ads_menuHeaderButtonRight" position="832px 0px" size="130px 40px" text="$l10n_ads_ingame_menu_header_last_inspection" onClick="onClickLastInspectionHeader">
                    <Bitmap profile="fs25_vehiclesHeaderIconSortAscending" position="10px 0px" id="iconInspectionAscending"/>
                    <Bitmap profile="fs25_vehiclesHeaderIconSortDescending" position="10px 0px" id="iconInspectionDescending"/>
                </Button>
                <Button profile="ads_menuHeaderButtonRight" position="968px 0px" size="130px 40px" text="$l10n_ads_ingame_menu_header_last_maintenance" onClick="onClickLastMaintenanceHeader">
                    <Bitmap profile="fs25_vehiclesHeaderIconSortAscending" position="10px 0px" id="iconMaintenanceAscending"/>
                    <Bitmap profile="fs25_vehiclesHeaderIconSortDescending" position="10px 0px" id="iconMaintenanceDescending"/>
                </Button>
                <Button profile="ads_menuHeaderButtonRight" position="1104px 0px" size="110px 40px" text="$l10n_ads_ingame_menu_header_cost" onClick="onClickCostHeader">
                    <Bitmap profile="fs25_vehiclesHeaderIconSortAscending" position="10px 0px" id="iconCostAscending"/>
                    <Bitmap profile="fs25_vehiclesHeaderIconSortDescending" position="10px 0px" id="iconCostDescending"/>
                </Button>
                <Button profile="ads_menuHeaderButtonRight" position="1220px 0px" size="110px 40px" text="$l10n_ads_ingame_menu_header_leasing_price" onClick="onClickLeasingPriceHeader">
                    <Bitmap profile="fs25_vehiclesHeaderIconSortAscending" position="10px 0px" id="iconLeasingAscending"/>
                    <Bitmap profile="fs25_vehiclesHeaderIconSortDescending" position="10px 0px" id="iconLeasingDescending"/>
                </Button>
                <Button profile="ads_menuHeaderButtonRight" position="1336px 0px" size="100px 40px" text="$l10n_ads_ingame_menu_header_price" onClick="onClickPriceHeader">
                    <Bitmap profile="fs25_vehiclesHeaderIconSortAscending" position="10px 0px" id="iconPriceAscending"/>
                    <Bitmap profile="fs25_vehiclesHeaderIconSortDescending" position="10px 0px" id="iconPriceDescending"/>
                </Button>
                <ThreePartBitmap profile="fs25_lineSeparatorBottom" position="0px -2dp"/>
            </GuiElement>

            <SmoothList profile="ads_menuVehicleList" id="vehicleList">
                <ListItem profile="ads_menuTableListItemAlt" id="vehicleTemplate" size="1460px 40.77px">
                    <ThreePartBitmap profile="ads_menuTableListItemGradient" name="alternating"/>
                    <Text profile="ads_menuTableRowCellLeftAlt" position="22px 0px" size="280px 40.77px" name="vehicleNameText" textLayoutMode="scrolling"/>
                    <Text profile="ads_menuTableRowCellRightAlt" position="308px 0px" size="110px 40.77px" name="ageText"/>
                    <Text profile="ads_menuTableRowCellRightAlt" position="424px 0px" size="110px 40.77px" name="workingHoursText"/>
                    <Text profile="ads_menuTableRowCellRightAlt" position="540px 0px" size="130px 40.77px" name="conditionText"/>
                    <Text profile="ads_menuTableRowCellRightAlt" position="676px 0px" size="130px 40.77px" name="intervalText"/>
                    <Text profile="ads_menuTableRowCellRightAlt" position="812px 0px" size="130px 40.77px" name="lastInspectionText" textLayoutMode="scrolling"/>
                    <Text profile="ads_menuTableRowCellRightAlt" position="948px 0px" size="130px 40.77px" name="lastMaintenanceText" textLayoutMode="scrolling"/>
                    <Text profile="ads_menuTableRowCellRightAlt" position="1084px 0px" size="110px 40.77px" name="costText"/>
                    <Text profile="ads_menuTableRowCellRightAlt" position="1200px 0px" size="110px 40.77px" name="leasingPriceText"/>
                    <Text profile="ads_menuTableRowCellRightAlt" position="1316px 0px" size="100px 40.77px" name="priceText"/>
                </ListItem>
            </SmoothList>

            <ThreePartBitmap profile="ads_menuListSliderBox">
                <Slider profile="fs25_listSlider" dataElementId="vehicleList"/>
            </ThreePartBitmap>

            <GuiElement profile="ads_menuFooterBox">
                <ThreePartBitmap profile="fs25_lineSeparatorTop" position="0px -15dp"/>
                <Text profile="ads_menuHeaderBright" position="22px 0px" size="280px 40.77px" id="totalLabel"/>
                <Text profile="ads_menuHeaderRightBright" position="1084px 0px" size="110px 40.77px" id="totalCost"/>
                <Text profile="ads_menuHeaderRightBright" position="1200px 0px" size="110px 40.77px" id="totalLeasingPrice"/>
                <Text profile="ads_menuHeaderRightBright" position="1316px 0px" size="100px 40.77px" id="totalPrice"/>
            </GuiElement>
        </GuiElement>

        <GuiElement profile="ads_menuDetailBox" id="detailBox">
            <Bitmap profile="fs25_vehiclesDetailsImageBg" position="0px 0px">
                <Bitmap profile="fs25_vehiclesDetailsImage" id="itemDetailsImage"/>
            </Bitmap>
            <InGameMapPreview profile="fs25_vehiclesIngameMap" id="itemDetailsMap" position="270px 12px"/>
            <Text profile="fs25_vehiclesDetailsName" id="itemDetailsName" position="530px 5px"/>
            <BoxLayout profile="fs25_vehiclesDetailsInfoBox" id="attributesLayout" position="530px -30px">
                <GuiElement profile="fs25_itemDetailsTemplateBox" name="detailTemplate">
                    <Bitmap profile="fs25_itemDetailsIcon" name="icon"/>
                    <Text profile="fs25_itemDetailsText" text="Default" name="text" textAutoWidth="true"/>
                </GuiElement>
                <GuiElement profile="fs25_itemDetailsTemplateBox" name="valueTemplate">
                    <Bitmap profile="shopListAttributeIconPrice" name="icon"/>
                    <Text profile="fs25_itemDetailsText" text="Dummy" name="text"/>
                </GuiElement>
            </BoxLayout>
        </GuiElement>
    </GuiElement>

</GUI>
