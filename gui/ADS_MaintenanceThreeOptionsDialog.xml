<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<GUI onOpen="onOpen" onClose="onClose" onCreate="onCreate">
    <GuiElement profile="newLayer" />
    <Bitmap profile="dialogFullscreenBg" id="dialogBg" />
    <GuiElement profile="ads_dialogBgLarge" id="dialogElement">
        <ThreePartBitmap profile="fs25_dialogBgMiddleSmall" />
        <ThreePartBitmap profile="fs25_dialogBgTopSmall" />
        <ThreePartBitmap profile="fs25_dialogBgBottom" />
        
        <GuiElement profile="fs25_dialogContentContainer">
            <Animation profile="fs25_dialogLoading" id="iconLoadingElement" />

            <!-- Title -->
            <Text profile="fs25_dialogTitle" id="dialogTitleElement" position="0px -30px" text="Maintenance Options"/>

            <!-- Option One -->
            <Text profile="fs25_dialogText" id="optionOneText" position="0px -90px" text="Select the extent of maintenance:"/>
            <MultiTextOption profile="ads_multiTextOption" id="optionOne" position="0px -120px" focusInit="onOpen" onClick="onClickOptionOne" texts="1|2|3|4" />
                
            <!-- Option Two -->
            <Text profile="fs25_dialogText" id="optionTwoText" position="0px -170px" text="Choose consumables:"/>
            <MultiTextOption profile="ads_multiTextOption" id="optionTwo" position="0px -200px" onClick="onClickOptionTwo" texts="1|2|3|4" />

            <Text profile="ads_disclaimerText" position="40px -245px" size="500px 30px" id="choosenPartsText" text="* Choosen parts for repair: Clutch, ECU."/>

            <!-- Price, duration, finish time -->
            <SmoothList profile="ads_dialogInfoTable" id="serviceInfoTable" position="0px -275px" size="400px 78px">
                <ListItem profile="ads_dialogInfoRow" name="serviceInfoRowTemplate" size="400px 26px">
                    <Text profile="ads_dialogInfoTitle" position="20px 0px" size="160px 26px" name="serviceInfoTitle" textLayoutMode="scrolling" />
                    <Text profile="ads_dialogInfoValue" position="190px 0px" size="190px 26px" name="serviceInfoValue" textLayoutMode="scrolling" />
                </ListItem>
            </SmoothList>

            <!-- Disclaimers -->
            <Text profile="ads_disclaimerText" position="40px -380px" size="500px 30px" id="optionOneDisclaimer" text="*Extended maintenance is more expensive and takes longer, but includes additional procedures that significantly extend the service interval until the next maintenance."/>
            <Text profile="ads_disclaimerText" position="40px -435px" size="500px 30px" id="optionTwoDisclaimer" text="**Premium parts have no risk of defects, but their cost is higher."/>
        
            <!-- Option Three -->
            <Text profile="fs25_dialogText" id="optionThreeText" position="0px -480px" text="Repair any faults found"/>
            <BinaryOption profile="fs25_binaryOption" id="optionThree" onClick="onClickOptionThree" size="300px 30px" position="0px 40px"/>

        </GuiElement>
        <BoxLayout profile="fs25_dialogButtonBox">
            <Button profile="buttonBack" text="$l10n_button_close" onClick="onClickBack" />
            <Button profile="buttonOK" text="$l10n_ads_option_menu_start_text" onClick="onClickStartService" />
        </BoxLayout>
    </GuiElement>

    <GUIProfiles>
        <Profile name="ads_dialogBgLarge" extends="fs25_dialogBg">
            <size value="600px 660px" />
        </Profile>

        <Profile name="ads_dialogSeparator" extends="baseReference" with="anchorTopCenter">
            <size value="500px 1dp" />
            <absoluteSizeOffset value="0px 0px" />
            <imageColor value="$preset_fs25_colorGreyLight_50" />
            <startImageSize value="30px 0px" />
            <startImageSliceId value="gui.list_divider" />
            <endImageSize value="0px 0px" />
            <endImageInvertX value="true" />
            <endImageSliceId value="gui.list_divider" />
        </Profile>

        <Profile name="ads_dialogInfoTable" extends="emptyPanel" with="anchorTopCenter">
        </Profile>

        <Profile name="ads_dialogInfoRow" extends="baseReference" with="anchorTopStretchingX alternating">
            <height value="26px" />
            <imageColor value="$preset_fs25_colorGrey" />
            <alternateBackgroundColor value="$preset_fs25_colorGreyDark_50" />
        </Profile>

        <Profile name="ads_dialogInfoTitle" extends="baseReference" with="anchorStretchingYLeft">
            <textBold value="false" />
            <textSize value="14px" />
            <textUpperCase value="true" />
            <textColor value="$preset_colorWhite_50" />
            <textAlignment value="left" />
            <textVerticalAlignment value="middle" />
            <textDisabledColor value="$preset_colorDisabled" />
        </Profile>

        <Profile name="ads_dialogInfoValue" extends="baseReference" with="anchorStretchingYLeft">
            <textBold value="false" />
            <textSize value="14px" />
            <textColor value="$preset_colorWhite_50" />
            <textAlignment value="right" />
            <textVerticalAlignment value="middle" />
            <textDisabledColor value="$preset_colorDisabled" />
        </Profile>
    </GUIProfiles>

</GUI>
