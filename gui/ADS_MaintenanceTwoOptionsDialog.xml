<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<GUI onOpen="onOpen" onClose="onClose" onCreate="onCreate">
    <GuiElement profile="newLayer" />
    <Bitmap profile="dialogFullscreenBg" id="dialogBg" />
    
    <GuiElement profile="ads_dialogBgSmall" id="dialogElement">
        <ThreePartBitmap profile="fs25_dialogBgMiddleSmall" />
        <ThreePartBitmap profile="fs25_dialogBgTopSmall" />
        <ThreePartBitmap profile="fs25_dialogBgBottom" />
        
        <GuiElement profile="fs25_dialogContentContainer">
            <Animation profile="fs25_dialogLoading" id="iconLoadingElement" />

            <!-- Title -->
            <Text profile="fs25_dialogTitle" id="dialogTitleElement" position="0px -30px" text="Maintenance Options"/>

            <!-- Option One -->
            <Text profile="fs25_dialogText" id="optionOneText" position="0px -80px" text="Select the extent of maintenance:"/>
            <MultiTextOption profile="ads_multiTextOption" id="optionOne" position="0px -110px" focusInit="onOpen" onClick="onClickOptionOne" texts="1|2|3|4" />
                
            <!-- Price, duration, finish time -->
            <SmoothList profile="ads_dialogInfoTable" id="serviceInfoTable" position="0px -185px" size="400px 78px">
                <ListItem profile="ads_dialogInfoRow" name="serviceInfoRowTemplate" size="400px 26px">
                    <Text profile="ads_dialogInfoTitle" position="20px 0px" size="160px 26px" name="serviceInfoTitle" textLayoutMode="scrolling" />
                    <Text profile="ads_dialogInfoValue" position="190px 0px" size="190px 26px" name="serviceInfoValue" textLayoutMode="scrolling" />
                </ListItem>
            </SmoothList>

            <!-- Disclaimers -->
            <Text profile="ads_disclaimerText" position="40px -295px" size="500px 30px" id="optionOneDisclaimer" text="*Extended maintenance is more expensive and takes longer, but includes additional procedures that significantly extend the service interval until the next maintenance."/>
        
            <!-- Option Three -->
            <Text profile="fs25_dialogText" id="optionThreeText" position="0px -360px" text="Repair any faults found"/>
            <Text profile="ads_disclaimerText" position="40px -430px" size="500px 30px" id="optionThreeDisclaimer" text="* Automatically start standard repair with OEM parts if faults are detected."/>
            <BinaryOption profile="fs25_binaryOption" id="optionThree" onClick="onClickOptionThree" size="300px 30px" position="0px 55px"/>

        </GuiElement>
        <BoxLayout profile="fs25_dialogButtonBox">
            <Button profile="buttonBack" text="$l10n_button_close" onClick="onClickBack" />
            <Button profile="buttonOK" id="startServiceButton" text="$l10n_ads_option_menu_start_text" onClick="onClickStartService" />
        </BoxLayout>
    </GuiElement>
</GUI>
